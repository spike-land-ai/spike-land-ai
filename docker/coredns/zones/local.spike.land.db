$ORIGIN local.spike.land.
@  IN SOA ns.local.spike.land. admin.local.spike.land. (
    2024010101  ; serial
    3600        ; refresh
    900         ; retry
    604800      ; expire
    86400       ; minimum
)

@  IN NS  ns.local.spike.land.
ns IN A   127.0.0.1
@  IN A   127.0.0.1
*  IN A   127.0.0.1
