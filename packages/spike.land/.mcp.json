{
  "mcpServers": {
    "spike": {
      "type": "stdio",
      "command": "npx",
      "args": ["@spike-land-ai/spike-cli", "serve"],
      "env": {
        "MCP_API_KEY": "${MCP_API_KEY}",
        "SPIKE_PROD_API_KEY": "${SPIKE_PROD_API_KEY}",
        "GH_PAT_TOKEN": "${GH_PAT_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--isolated"]
    }
  }
}
