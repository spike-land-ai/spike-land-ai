---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';

const plans = [
    {
      id: "free",
      name: "Free",
      price: "$0",
      period: "/month",
      description: "Perfect for individuals getting started with AI agents.",
      features: [
        "Access to CodeSpace",
        "Community Support",
        "Basic Agent Orchestration"
      ],
      cta: "Start Free",
      highlighted: false,
    },
    {
      id: "pro",
      name: "Pro",
      price: "$29",
      period: "/month",
      description: "For professional developers building production apps.",
      features: [
        "Everything in Free",
        "QA Studio Access",
        "Priority Support",
        "Unlimited Agent Runs"
      ],
      cta: "Upgrade to Pro",
      highlighted: true,
    },
    {
      id: "business",
      name: "Business",
      price: "$99",
      period: "/month",
      description: "For teams collaborating on AI systems.",
      features: [
        "Everything in Pro",
        "Ops Dashboard",
        "Team Collaboration",
        "Custom Domains"
      ],
      cta: "Upgrade to Business",
      highlighted: false,
    },
    {
      id: "enterprise",
      name: "Enterprise",
      price: "Custom",
      period: "",
      description: "For organizations with custom requirements.",
      features: [
        "Everything in Business",
        "Dedicated Success Manager",
        "Custom Integrations",
        "SLA"
      ],
      cta: "Contact Sales",
      highlighted: false,
    }
];

const faqs = [
  {
    q: "Can I switch plans anytime?",
    a: "Yes. Upgrades take effect immediately; downgrades take effect at the end of your billing cycle.",
  },
  {
    q: "What payment methods do you accept?",
    a: "We accept all major credit cards, debit cards, and bank transfers for annual plans.",
  },
  {
    q: "Is there a free trial on paid plans?",
    a: "Pro and Business plans come with a 14-day free trial — no credit card required.",
  },
  {
    q: "What counts as an 'agent run'?",
    a: "An agent run is a single end-to-end execution of an MCP agent task. Free plans include 100 runs/month.",
  },
];
---

<Layout
  title="Pricing - spike.land"
  description="Simple, transparent pricing for spike.land. Start for free, upgrade when you need more power."
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/pricing" />

    <main>
      <!-- Header -->
      <section class="pricing-header">
        <div class="rubik-container pricing-header-inner">
          <p class="rubik-eyebrow">Pricing</p>
          <h1 class="pricing-title">Simple, transparent pricing.</h1>
          <p class="rubik-lede">Start for free, upgrade when you need more power. No hidden fees.</p>
        </div>
      </section>

      <!-- Plans grid -->
      <section class="plans-section">
        <div class="rubik-container">
          <p id="pricing-feedback" class="pricing-feedback" role="status" aria-live="polite" hidden></p>
          <div class="plans-grid">
            {plans.map(plan => (
              <div class={`plan-card ${plan.highlighted ? 'plan-card--pro' : ''}`}>
                {plan.highlighted && (
                  <div class="pro-badge">Most Popular</div>
                )}

                <div class="plan-header">
                  <h2 class="plan-name">{plan.name}</h2>
                  <div class="plan-price-row">
                    <span class="plan-price">{plan.price}</span>
                    {plan.period && <span class="plan-period">{plan.period}</span>}
                  </div>
                  <p class="plan-desc">{plan.description}</p>
                </div>

                <ul class="plan-features">
                  {plan.features.map(feature => (
                    <li class="feature-row">
                      <svg class="feature-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>

                <div class="plan-cta-wrap">
                  {plan.id === 'free' && (
                    <a href="/login" class={`plan-cta ${plan.highlighted ? 'plan-cta--primary' : 'plan-cta--secondary'}`}>
                      {plan.cta}
                    </a>
                  )}
                  {plan.id === 'pro' && (
                    <button
                      class="plan-cta plan-cta--primary"
                      type="button"
                      data-checkout-tier="pro"
                    >
                      {plan.cta}
                    </button>
                  )}
                  {plan.id === 'business' && (
                    <button
                      class="plan-cta plan-cta--secondary"
                      type="button"
                      data-checkout-tier="business"
                    >
                      {plan.cta}
                    </button>
                  )}
                  {plan.id === 'enterprise' && (
                    <a href="mailto:hello@spike.land?subject=Enterprise%20Plan" class="plan-cta plan-cta--secondary">
                      {plan.cta}
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Feature comparison table -->
      <section class="comparison-section">
        <div class="rubik-container">
          <h2 class="comparison-title">Compare features</h2>
          <div class="comparison-table rubik-panel" style="padding: 0; overflow: hidden;">
            <table class="comp-table">
              <thead>
                <tr class="comp-head-row">
                  <th class="comp-feature-col">Feature</th>
                  <th>Free</th>
                  <th>Pro</th>
                  <th>Business</th>
                  <th>Enterprise</th>
                </tr>
              </thead>
              <tbody>
                <tr class="comp-row">
                  <td class="comp-feature">CodeSpace</td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">QA Studio</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Ops Dashboard</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Agent Runs/mo</td>
                  <td>100</td>
                  <td>Unlimited</td>
                  <td>Unlimited</td>
                  <td>Unlimited</td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Team Members</td>
                  <td>1</td>
                  <td>3</td>
                  <td>25</td>
                  <td>Unlimited</td>
                </tr>
                <tr class="comp-row">
                  <td class="comp-feature">Custom Domains</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
                <tr class="comp-row comp-row-last">
                  <td class="comp-feature">SLA</td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-dash">—</span></td>
                  <td><span class="comp-check">✓</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="faq-section">
        <div class="rubik-container faq-inner">
          <h2 class="faq-title">Frequently asked</h2>
          <div class="faq-list">
            {faqs.map((faq, i) => (
              <details class="faq-item" name="faq">
                <summary class="faq-q">
                  {faq.q}
                  <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </summary>
                <p class="faq-a">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- Enterprise CTA -->
      <section class="enterprise-cta">
        <div class="rubik-container">
          <div class="enterprise-card glass-card">
            <div class="enterprise-content">
              <p class="rubik-eyebrow">Enterprise</p>
              <h2 class="enterprise-title">Need something custom?</h2>
              <p class="rubik-lede enterprise-lede">We work with teams of all sizes. Custom contracts, dedicated infrastructure, and white-glove onboarding.</p>
            </div>
            <a href="mailto:hello@spike.land?subject=Enterprise%20Plan" class="enterprise-cta-btn">
              Talk to Sales
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
    <CookieConsent />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* Header */
  .pricing-header {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--border-color);
    background: radial-gradient(ellipse 70% 50% at 50% 0%, color-mix(in srgb, var(--primary-color) 8%, transparent), transparent);
  }

  .pricing-header-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    align-items: center;
  }

  .pricing-title { max-width: 22ch; }

  /* Plans grid */
  .plans-section {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .pricing-feedback {
    margin: 0 0 1rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--primary-color) 25%, var(--border-color));
    background: color-mix(in srgb, var(--primary-color) 8%, var(--card-bg));
    color: var(--fg);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .plan-card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: box-shadow var(--duration-normal) var(--ease);
  }

  .plan-card:hover {
    box-shadow: var(--shadow-md);
  }

  .plan-card--pro {
    border-color: var(--primary-color);
    background: color-mix(in srgb, var(--primary-color) 4%, var(--card-bg));
    box-shadow: 0 0 0 1px var(--primary-color),
                0 0 24px color-mix(in srgb, var(--primary-color) 15%, transparent);
  }

  .plan-card--pro:hover {
    box-shadow: 0 0 0 1px var(--primary-color),
                0 0 40px color-mix(in srgb, var(--primary-color) 22%, transparent),
                var(--shadow-lg);
  }

  .pro-badge {
    position: absolute;
    top: -0.875rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary-color);
    color: var(--primary-fg);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.25rem 0.875rem;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: var(--shadow-sm);
  }

  .plan-header { display: flex; flex-direction: column; gap: 0.5rem; }

  .plan-name {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .plan-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .plan-price {
    font-size: 2.25rem;
    font-weight: 900;
    font-family: var(--font-display);
    letter-spacing: -0.04em;
    font-variation-settings: "wght" 900;
  }

  .plan-period {
    font-size: 0.875rem;
    color: var(--muted-fg);
  }

  .plan-desc {
    font-size: 0.875rem;
    color: var(--muted-fg);
    line-height: 1.55;
    margin: 0;
    min-height: 2.5rem;
  }

  .plan-features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .feature-row {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .feature-check {
    color: var(--primary-color);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .plan-cta-wrap { margin-top: 0.5rem; }

  .plan-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.6875rem 1rem;
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: opacity var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .plan-cta--primary {
    background: var(--primary-color);
    color: var(--primary-fg);
    box-shadow: var(--shadow-sm);
  }

  .plan-cta--secondary {
    background: var(--fg);
    color: var(--bg);
  }

  .plan-cta:hover { opacity: 0.88; transform: translateY(-1px); }
  .plan-cta:active { transform: translateY(0); }
  .plan-cta:disabled {
    opacity: 0.65;
    cursor: wait;
    transform: none;
  }

  /* Comparison table */
  .comparison-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .comparison-title {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .comp-head-row th {
    padding: 0.875rem 1.25rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--muted-fg);
    background: var(--muted-bg);
    border-bottom: 1px solid var(--border-color);
  }

  .comp-head-row th.comp-feature-col {
    text-align: left;
  }

  .comp-row td {
    padding: 0.75rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
    color: var(--fg);
  }

  .comp-row td.comp-feature {
    text-align: left;
    color: var(--muted-fg);
    font-weight: 500;
  }

  .comp-row-last td { border-bottom: none; }
  .comp-row:hover td { background: var(--muted-bg); }

  .comp-check { color: var(--primary-color); font-size: 1rem; }
  .comp-dash { color: var(--border-color); }

  /* FAQ */
  .faq-section {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .faq-inner { max-width: 52rem; }

  .faq-title {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .faq-list { display: flex; flex-direction: column; gap: 0; }

  .faq-item {
    border-bottom: 1px solid var(--border-color);
  }

  .faq-item:first-child { border-top: 1px solid var(--border-color); }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.125rem 0;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: var(--fg);
    transition: color var(--duration-fast) var(--ease);
  }

  .faq-q:hover { color: var(--primary-color); }
  .faq-q::-webkit-details-marker { display: none; }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--muted-fg);
    transition: transform var(--duration-normal) var(--ease);
  }

  details[open] .faq-chevron { transform: rotate(180deg); }

  .faq-a {
    padding: 0 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--muted-fg);
    margin: 0;
  }

  /* Enterprise CTA */
  .enterprise-cta {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--border-color);
  }

  .enterprise-card {
    padding: clamp(2rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .enterprise-content { display: flex; flex-direction: column; gap: 0.75rem; }
  .enterprise-title { font-size: clamp(1.375rem, 2vw, 1.875rem); margin: 0; }
  .enterprise-lede { margin: 0; }

  .enterprise-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--fg);
    color: var(--bg);
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
    box-shadow: var(--shadow-md);
  }

  .enterprise-cta-btn:hover { opacity: 0.88; transform: translateY(-1px); }
</style>

<script>
  const feedback = document.getElementById('pricing-feedback');
  const checkoutButtons = Array.from(document.querySelectorAll('[data-checkout-tier]'));

  function setFeedback(message: string | null) {
    if (!feedback) return;
    if (!message) {
      feedback.hidden = true;
      feedback.textContent = '';
      return;
    }

    feedback.hidden = false;
    feedback.textContent = message;
  }

  async function startCheckout(button: HTMLButtonElement) {
    const tier = button.dataset.checkoutTier;
    if (!tier) return;

    const originalLabel = button.textContent?.trim() || 'Continue';
    setFeedback(null);
    button.disabled = true;
    button.textContent = 'Redirecting…';

    try {
      const res = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ tier })
      });
      if (res.status === 401) {
        window.location.href = '/login?redirect=/pricing';
        return;
      }

      const data = await res.json().catch(() => null);
      if (!res.ok) {
        throw new Error(
          typeof data?.error === 'string' ? data.error : `Unable to start checkout (${res.status})`,
        );
      }

      if (typeof data?.url !== 'string' || data.url.length === 0) {
        throw new Error('No checkout URL returned.');
      }

      window.location.href = data.url;
    } catch (err) {
      console.error('Checkout error:', err);
      setFeedback(
        err instanceof Error ? err.message : 'Unable to start checkout right now. Please try again.',
      );
    } finally {
      button.disabled = false;
      button.textContent = originalLabel;
    }
  }

  checkoutButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    button.addEventListener('click', () => {
      void startCheckout(button);
    });
  });
</script>
