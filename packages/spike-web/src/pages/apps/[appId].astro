---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import QaStudioPage from '../../components/react/qa-studio/QaStudioApp.tsx';
import SpikeChatPage from '../../components/apps/SpikeChatPage.astro';
import Analytics from '../../components/Analytics.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import { appCatalog, getAppById } from '../../data/apps';

export function getStaticPaths() {
  return appCatalog.map((app) => ({
    params: { appId: app.id },
  }));
}

const { appId } = Astro.params;
const app = getAppById(appId);

if (!app) {
  throw new Error(`Unknown app: ${appId}`);
}

const appName = app.name;
---

<Layout
  title={`${appName} — spike.land`}
  description={app.description}
>
  <Analytics slot="head" />
  <div class="page-shell">
    {appId === 'qa-studio' ? (
        <main class="flex-1 w-full h-screen overflow-hidden">
            <QaStudioPage client:only="react" />
        </main>
    ) : appId === 'spike-chat' ? (
      <>
        <Nav activePath="/apps" />
        <main class="spike-chat-main">
          <SpikeChatPage
            name={app.name}
            description={app.description}
            accent={app.accent}
            accentBg={app.accentBg}
          />
        </main>
        <Footer />
      </>
    ) : (
      <>
        <Nav activePath="/apps" />
        <div class="app-workspace">
          <!-- App top bar -->
          <div class="app-topbar">
            <div class="app-topbar-left">
              <a href="/apps" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                Apps
              </a>
              <div class="topbar-divider"></div>
              <span class="app-topbar-name">{app.name}</span>
              <span class={`status-badge status-${app.status.toLowerCase()}`}>
                <span class="status-dot"></span> {app.status}
              </span>
            </div>
            <div class="app-topbar-right">
              <span class="topbar-chip">Preview mode</span>
            </div>
          </div>

          <div class="app-body">
            <!-- Main Content Area -->
            <main class="app-main">
              <!-- Tab Navigation -->
              <div class="tab-nav">
                <button class="tab-btn tab-active" data-target="panel-overview">Overview</button>
                <button class="tab-btn" data-target="panel-editor">Editor</button>
                <button class="tab-btn" data-target="panel-terminal">Terminal</button>
              </div>

              <!-- Panels -->
              <div class="tab-content">
                <div id="panel-overview" class="tab-panel tab-panel-active p-8 space-y-6">
                  <div class="overview-card rubik-panel" style="max-width: 42rem;">
                    <h2 class="overview-title">{app.name} Overview</h2>
                    <p class="overview-desc">{app.description}</p>
                    <div class="overview-specs">
                      <div class="spec-row">
                        <span class="spec-label">Framework</span>
                        <span class="spec-value">Astro 5 (Pure)</span>
                      </div>
                      <div class="spec-row">
                        <span class="spec-label">Last Deployed</span>
                        <span class="spec-value">Just now</span>
                      </div>
                      <div class="spec-row">
                        <span class="spec-label">Runtime</span>
                        <span class="spec-value">Cloudflare Workers</span>
                      </div>
                    </div>
                  </div>
                </div>

                <div id="panel-editor" class="tab-panel editor-panel">
                  <div class="editor-placeholder">
                    <span>[ Monaco Editor Island ]</span>
                  </div>
                </div>

                <div id="panel-terminal" class="tab-panel terminal-panel">
                  <div class="terminal-line terminal-prompt">$ spike-cli start</div>
                  <div class="terminal-line terminal-muted">Initializing MCP servers...</div>
                  <div class="terminal-line terminal-muted">Environment ready. Waiting for commands.</div>
                  <div class="terminal-line terminal-cursor">▌</div>
                </div>
              </div>
            </main>

            <!-- Sidebar Chat -->
            <aside class="agent-sidebar">
              <div class="sidebar-header">
                Agent Chat
                <div class="agent-online-dot"></div>
              </div>
              <div class="sidebar-messages" id="agent-messages" aria-live="polite">
                <div class="agent-message">
                  <div class="agent-bubble">
                    Hello! I've scaffolded the initial environment. How can I help you customize it?
                  </div>
                </div>
              </div>
              <div class="sidebar-input-wrap">
                <form class="sidebar-composer" id="agent-chat-form" data-app-name={app.name}>
                  <div
                    class="sidebar-attachment-list"
                    id="agent-attachment-list"
                    hidden
                    aria-live="polite"
                  ></div>
                  <div class="sidebar-composer-row">
                    <label class="sidebar-tool-btn" for="agent-attachment-input" title="Add attachments">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21.44 11.05l-8.49 8.49a6 6 0 01-8.49-8.49l9.19-9.2a4 4 0 115.66 5.66l-9.2 9.2a2 2 0 11-2.82-2.83l8.49-8.48"/>
                      </svg>
                      <span>Attach</span>
                    </label>
                    <input
                      id="agent-attachment-input"
                      class="sidebar-file-input"
                      type="file"
                      multiple
                    />
                    <textarea
                      id="agent-chat-input"
                      class="sidebar-input"
                      rows="1"
                      placeholder="Ask the agent or add attachments…"
                    ></textarea>
                    <button
                      id="agent-send-btn"
                      type="submit"
                      class="sidebar-send-btn"
                      aria-label="Send message"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 2L11 13"/>
                        <path d="M22 2l-7 20-4-9-9-4z"/>
                      </svg>
                      <span>Send</span>
                    </button>
                  </div>
                </form>
              </div>
            </aside>
          </div>
        </div>
      </>
    )}
    <CookieConsent />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .spike-chat-main {
    flex: 1;
  }

  /* App workspace */
  .app-workspace {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: calc(100svh - 4rem); /* 4rem = nav height */
  }

  .app-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    height: 3.25rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--card-bg);
    flex-shrink: 0;
  }

  .app-topbar-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .back-link:hover { color: var(--fg); }

  .topbar-divider {
    width: 1px;
    height: 1rem;
    background: var(--border-color);
  }

  .app-topbar-name {
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.625rem;
    border-radius: 999px;
  }

  .status-live {
    background: rgba(22,163,74,0.12);
    color: #16a34a;
    border: 1px solid rgba(22,163,74,0.2);
  }

  .status-beta {
    background: rgba(234,88,12,0.12);
    color: #ea580c;
    border: 1px solid rgba(234,88,12,0.2);
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: currentColor;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .topbar-chip {
    padding: 0.375rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--fg);
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  .app-body {
    flex: 1;
    display: flex;
    overflow: hidden;
  }

  /* Main panel */
  .app-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }

  .tab-nav {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border-color);
    padding-inline: 1rem;
    background: var(--bg);
    flex-shrink: 0;
  }

  .tab-btn {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    background: transparent;
    color: var(--muted-fg);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-fast) var(--ease),
                border-color var(--duration-fast) var(--ease);
    font-family: var(--font-sans);
    margin-bottom: -1px;
  }

  .tab-btn:hover { color: var(--fg); }

  .tab-active {
    color: var(--fg);
    border-bottom-color: var(--primary-color);
  }

  .tab-content {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .tab-panel {
    position: absolute;
    inset: 0;
    overflow: auto;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s var(--ease);
  }

  .tab-panel-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Overview */
  .overview-card { margin: 0; }

  .overview-title {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
  }

  .overview-desc {
    font-size: 0.9375rem;
    color: var(--muted-fg);
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .overview-specs { display: flex; flex-direction: column; gap: 0; }

  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .spec-row:last-child { border-bottom: none; }
  .spec-label { font-size: 0.875rem; color: var(--muted-fg); }
  .spec-value { font-size: 0.875rem; font-weight: 500; }

  /* Editor */
  .editor-panel {
    background: #0d1117;
  }

  .editor-placeholder {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  /* Terminal */
  .terminal-panel {
    background: #0a0a0a;
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .terminal-line { line-height: 1.6; }
  .terminal-prompt { color: #4ade80; }
  .terminal-muted { color: #555; }
  .terminal-cursor { color: #888; animation: blink 1s step-end infinite; }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* Sidebar */
  .agent-sidebar {
    width: 20rem;
    border-left: 1px solid var(--border-color);
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .sidebar-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    font-weight: 600;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .agent-online-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #16a34a;
  }

  .sidebar-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .agent-message {
    display: flex;
    justify-content: flex-start;
  }

  .agent-message--user {
    justify-content: flex-end;
  }

  .agent-bubble {
    background: var(--muted-bg);
    border-radius: var(--radius-md);
    border-top-left-radius: 0.25rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--fg);
    max-width: min(100%, 18rem);
  }

  .agent-bubble--user {
    background: color-mix(in srgb, var(--primary-color) 14%, var(--card-bg));
    border-top-left-radius: var(--radius-md);
    border-top-right-radius: 0.25rem;
  }

  .sidebar-input-wrap {
    padding: 0.875rem;
    border-top: 1px solid var(--border-color);
  }

  .sidebar-composer {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .sidebar-composer-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.625rem;
    align-items: end;
  }

  .sidebar-file-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sidebar-tool-btn,
  .sidebar-send-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    min-height: 2.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background: var(--muted-bg);
    color: var(--fg);
    cursor: pointer;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: var(--font-sans);
    transition: background var(--duration-fast) var(--ease),
                border-color var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .sidebar-tool-btn:hover,
  .sidebar-send-btn:hover {
    background: color-mix(in srgb, var(--muted-bg) 88%, var(--fg) 12%);
  }

  .sidebar-send-btn {
    background: var(--fg);
    color: var(--bg);
    border-color: transparent;
  }

  .sidebar-send-btn:hover {
    background: color-mix(in srgb, var(--fg) 88%, var(--primary-color) 12%);
  }

  .sidebar-send-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }

  .sidebar-input {
    width: 100%;
    min-height: 2.75rem;
    max-height: 8rem;
    padding: 0.75rem 0.875rem;
    background: var(--bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--fg);
    font-family: var(--font-sans);
    transition: border-color var(--duration-fast) var(--ease);
    resize: none;
    overflow-y: auto;
  }

  .sidebar-input:focus {
    outline: none;
    border-color: var(--ring-color);
  }

  .sidebar-input::placeholder { color: var(--muted-fg); }

  .sidebar-attachment-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sidebar-attachment-list--message {
    margin-top: 0.625rem;
  }

  .sidebar-attachment-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    max-width: 100%;
    padding: 0.375rem 0.625rem;
    border-radius: 999px;
    border: 1px solid var(--border-color);
    background: color-mix(in srgb, var(--muted-bg) 82%, var(--bg) 18%);
    font-size: 0.75rem;
    color: var(--fg);
  }

  .sidebar-attachment-chip span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-attachment-remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.125rem;
    height: 1.125rem;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
    padding: 0;
    font: inherit;
  }

  .sidebar-attachment-remove:hover {
    background: color-mix(in srgb, var(--fg) 12%, transparent);
  }

  @media (max-width: 960px) {
    .app-body {
      flex-direction: column;
    }

    .app-main {
      min-height: 22rem;
    }

    .agent-sidebar {
      width: 100%;
      min-height: 22rem;
      border-left: none;
      border-top: 1px solid var(--border-color);
    }
  }

  @media (max-width: 640px) {
    .app-topbar {
      padding-inline: 0.875rem;
    }

    .tab-nav {
      overflow-x: auto;
    }

    .tab-btn {
      white-space: nowrap;
    }

    .sidebar-tool-btn span,
    .sidebar-send-btn span {
      display: none;
    }

    .sidebar-tool-btn,
    .sidebar-send-btn {
      padding-inline: 0.75rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('tab-active'));
      panels.forEach(p => p.classList.remove('tab-panel-active'));
      tab.classList.add('tab-active');
      const targetId = tab.getAttribute('data-target');
      if (targetId) {
        document.getElementById(targetId)?.classList.add('tab-panel-active');
      }
    });
  });

  const chatForm = document.getElementById('agent-chat-form');
  const chatInput = document.getElementById('agent-chat-input');
  const attachmentInput = document.getElementById('agent-attachment-input');
  const attachmentList = document.getElementById('agent-attachment-list');
  const sendButton = document.getElementById('agent-send-btn');
  const messageList = document.getElementById('agent-messages');

  if (
    chatForm instanceof HTMLFormElement &&
    chatInput instanceof HTMLTextAreaElement &&
    attachmentInput instanceof HTMLInputElement &&
    attachmentList instanceof HTMLDivElement &&
    sendButton instanceof HTMLButtonElement &&
    messageList instanceof HTMLDivElement
  ) {
    const selectedFiles = [];
    const appName = chatForm.dataset.appName || 'your app';

    const autoresizeInput = () => {
      chatInput.style.height = 'auto';
      chatInput.style.height = `${Math.min(chatInput.scrollHeight, 128)}px`;
    };

    const syncComposerState = () => {
      sendButton.disabled = chatInput.value.trim().length === 0 && selectedFiles.length === 0;
    };

    const renderPendingAttachments = () => {
      attachmentList.innerHTML = '';
      attachmentList.hidden = selectedFiles.length === 0;

      selectedFiles.forEach((file, index) => {
        const chip = document.createElement('span');
        chip.className = 'sidebar-attachment-chip';

        const label = document.createElement('span');
        label.textContent = file.name;
        chip.appendChild(label);

        const removeButton = document.createElement('button');
        removeButton.type = 'button';
        removeButton.className = 'sidebar-attachment-remove';
        removeButton.dataset.index = String(index);
        removeButton.setAttribute('aria-label', `Remove ${file.name}`);
        removeButton.textContent = '×';
        chip.appendChild(removeButton);

        attachmentList.appendChild(chip);
      });
    };

    const appendMessage = (role, text, attachments = []) => {
      const message = document.createElement('div');
      message.className = `agent-message ${role === 'user' ? 'agent-message--user' : ''}`.trim();

      const bubble = document.createElement('div');
      bubble.className = `agent-bubble ${role === 'user' ? 'agent-bubble--user' : ''}`.trim();

      if (text) {
        const body = document.createElement('div');
        body.textContent = text;
        bubble.appendChild(body);
      }

      if (attachments.length > 0) {
        const chips = document.createElement('div');
        chips.className = 'sidebar-attachment-list sidebar-attachment-list--message';

        attachments.forEach((name) => {
          const chip = document.createElement('span');
          chip.className = 'sidebar-attachment-chip';
          const label = document.createElement('span');
          label.textContent = name;
          chip.appendChild(label);
          chips.appendChild(chip);
        });

        bubble.appendChild(chips);
      }

      message.appendChild(bubble);
      messageList.appendChild(message);
      messageList.scrollTop = messageList.scrollHeight;
    };

    const buildAssistantReply = (text, attachments) => {
      const responseParts = [];

      if (attachments.length > 0) {
        responseParts.push(
          attachments.length === 1
            ? `Attachment received. I can fold it into the next ${appName} pass.`
            : `${attachments.length} attachments received. I can use them to shape the next ${appName} iteration.`,
        );
      }

      if (text) {
        responseParts.push(`Next step noted: ${text}`);
      } else {
        responseParts.push(`Tell me what you want changed and I will map it into the scaffold.`);
      }

      return responseParts.join(' ');
    };

    attachmentList.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) return;

      const index = Number.parseInt(target.dataset.index || '', 10);
      if (!Number.isFinite(index)) return;

      selectedFiles.splice(index, 1);
      renderPendingAttachments();
      syncComposerState();
    });

    attachmentInput.addEventListener('change', () => {
      const files = Array.from(attachmentInput.files || []);

      files.forEach((file) => {
        const alreadySelected = selectedFiles.some(
          (entry) =>
            entry.name === file.name &&
            entry.size === file.size &&
            entry.lastModified === file.lastModified,
        );

        if (!alreadySelected) {
          selectedFiles.push(file);
        }
      });

      attachmentInput.value = '';
      renderPendingAttachments();
      syncComposerState();
    });

    chatInput.addEventListener('input', () => {
      autoresizeInput();
      syncComposerState();
    });

    chatInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        chatForm.requestSubmit();
      }
    });

    chatForm.addEventListener('submit', (event) => {
      event.preventDefault();

      const text = chatInput.value.trim();
      const attachments = selectedFiles.map((file) => file.name);
      if (!text && attachments.length === 0) return;

      appendMessage(role = 'user', text || 'Shared attachments for the current scaffold.', attachments);

      chatInput.value = '';
      selectedFiles.length = 0;
      renderPendingAttachments();
      autoresizeInput();
      syncComposerState();

      window.setTimeout(() => {
        appendMessage('assistant', buildAssistantReply(text, attachments));
      }, 280);
    });

    autoresizeInput();
    syncComposerState();
  }
</script>
