---
import { ScrollStoryCard } from '../../../../../src/core/block-website/animation-ui/ScrollStoryCard';

interface Props {
  title: string;
  illustration: 'restaurant' | 'usb' | 'embassy' | 'brain';
  mappings?: Array<{ left: string; right: string }>;
}

const { title, illustration, mappings } = Astro.props;
---
<div class="not-prose my-8">
  <ScrollStoryCard client:visible title={title} illustration={illustration} mappings={mappings} />
</div>
