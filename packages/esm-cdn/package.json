{
  "name": "@spike-land-ai/esm-cdn",
  "description": "Cloudflare Worker proxying npm packages as ES modules via esm.spike.land",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.12.20",
    "@cloudflare/workers-types": "4.20260307.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "wrangler": "4.71.0"
  }
}
